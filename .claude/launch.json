{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api-server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "api-server", "dev"],
      "port": 3000,
      "env": {
        "PORT": "3000",
        "DATABASE_URL": "postgresql://localhost:5432/photonics_dev"
      }
    },
    {
      "name": "photonics-sim",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "photonics-sim", "dev"],
      "port": 5173,
      "env": {
        "PORT": "5173",
        "BASE_PATH": "/"
      }
    },
    {
      "name": "mockup-sandbox",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "mockup-sandbox", "dev"],
      "port": 5174,
      "env": {
        "PORT": "5174",
        "BASE_PATH": "/"
      }
    }
  ]
}
